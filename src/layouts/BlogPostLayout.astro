---
import BaseLayout from "./BaseLayout.astro";

type Props = {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
};

const { title, description, pubDate, updatedDate, tags } = Astro.props;
const dateFormatter = new Intl.DateTimeFormat("ko-KR", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const siteUrl = "https://park-moen.github.io";
const postUrl = new URL(Astro.url.pathname, siteUrl).href;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  url: postUrl,
  author: {
    "@type": "Person",
    name: "Park moen",
    url: siteUrl,
  },
  publisher: {
    "@type": "Person",
    name: "Park moen",
    url: siteUrl,
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": postUrl,
  },
  keywords: tags,
};
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  publishedTime={pubDate}
  modifiedTime={updatedDate ?? pubDate}
  tags={tags}
  jsonLd={jsonLd}
>
  <article class="post">
    <header class="post-header">
      <a class="back-link" href="/">← Posts</a>
      <h1>{title}</h1>
      <p class="post-description">{description}</p>
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}
          >{dateFormatter.format(pubDate)}</time
        >
        {
          updatedDate && (
            <span>
              Updated{" "}
              <time datetime={updatedDate.toISOString()}>
                {dateFormatter.format(updatedDate)}
              </time>
            </span>
          )
        }
      </div>
      {
        tags.length > 0 && (
          <ul class="tag-list" aria-label="태그">
            {tags.map((tag) => (
              <li>
                <a href={`/tags/${tag.toLowerCase()}/`}>{tag}</a>
              </li>
            ))}
          </ul>
        )
      }
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
